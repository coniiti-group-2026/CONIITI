# CONIITI local development placeholders
# Copy to .env.local when using scripts that load local values.

POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DEFAULT_DB=default_db

MONGO_USER=admin
MONGO_PASSWORD=replace-with-local-mongo-password
MONGO_DB_NAME=analytics_db

RABBITMQ_USER=user
RABBITMQ_PASS=replace-with-local-rabbitmq-password
RABBITMQ_EXCHANGE=coniiti_events

JWT_SECRET_KEY=replace-with-local-jwt-secret-at-least-32-chars
INTERNAL_SERVICE_TOKEN=replace-with-local-internal-service-token

FRONTEND_URL=http://localhost
VITE_API_URL=/api
VITE_API_ORIGIN=http://localhost

SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=CONIITI

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/auth/oauth/google/callback

MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost/api/auth/oauth/microsoft/callback

PAYMENT_PROVIDER_MODE=mock
PUBLIC_APP_URL=http://localhost
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
MP_ACCESS_TOKEN=
