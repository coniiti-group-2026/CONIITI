# ════════════════════════════════════════
#   CONIITI — .gitignore global
#   Aplica a Front-end/ y Back-end/
# ════════════════════════════════════════

# ── Dependencias Node ──
node_modules/
dist/
dist-ssr/

# ── Entornos virtuales Python ──
.venv/
venv/
env/
ENV/

# ── Variables de entorno (NO subir credenciales) ──
.env
.env.*
**/.env
**/.env.*
microservices/*/.env
!.env.example
!**/.env.example
!.env.local.example
!**/.env.local.example

# ── Python compilado ──
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd

# ── Bases de datos locales ──
*.db
*.sqlite
*.sqlite3

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Caches de herramientas ──
.vite/
.eslintcache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage/

# ── Distribución / empaquetado Python ──
build/
*.egg-info/
*.egg

# ── Editores ──
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Secrets ──
*.pem
*.key
*.cert
secrets.json
